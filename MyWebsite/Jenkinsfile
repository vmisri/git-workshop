pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Display Files') {
            steps {
                sh 'pwd'
                sh 'ls -la'
            }
        }

        stage('Create ZIP') {
            steps {
                sh '''
                cd MyWebsite
                zip -r website.zip .
                '''
            }
        }

        stage('Upload to S3') {
            steps {
                sh '''
                aws s3 cp MyWebsite/website.zip s3://jenkins-codedeploy-25-06-2026/website.zip
                '''
            }
        }

        stage('Deploy to CodeDeploy') {
            steps {
                sh '''
                aws deploy create-deployment \
                  --application-name MyWebApplication \
                  --deployment-group-name MyDeploymentGroup \
                  --s3-location bucket=jenkins-codedeploy-25-06-2026,key=website.zip,bundleType=zip \
                  --region us-east-1
                '''
            }
        }

    }
}
